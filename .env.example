# ═══════════════════════════════════════════════════════════════════════════════
# PMO Portal — Variables de Entorno
# Arquitectura: Todo en Azure — Web App + PostgreSQL + Enterprise Application
# ═══════════════════════════════════════════════════════════════════════════════

# ── Microsoft Enterprise Application ──────────────────────────────────────────
# Se obtienen de Azure Portal → Enterprise Applications → PMO Portal
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Frontend (mismos valores, prefijo VITE_ para Vite)
VITE_AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Group IDs de Enterprise Application (para mapeo de roles) ─────────────────
# Obtener de Azure Portal → Entra ID → Groups → cada grupo → Object ID
GROUP_ID_ADMINS=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GROUP_ID_DIRECTORES=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GROUP_ID_GERENTES=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GROUP_ID_LIDERES=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GROUP_ID_USUARIOS=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Azure Database for PostgreSQL ─────────────────────────────────────────────
# Formato: postgresql://USUARIO:PASSWORD@SERVIDOR.postgres.database.azure.com:5432/BD?sslmode=require
DATABASE_URL=postgresql://pmo_admin:TuPassword@pmo-server.postgres.database.azure.com:5432/pmo_portal?sslmode=require

# ── Aplicación ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
WEBSITES_PORT=8080
FRONTEND_URL=https://pmo.tudominio.com
VITE_API_URL=/api

# Secret para JWT (generar con: openssl rand -hex 32)
JWT_SECRET=cambia_esto_por_algo_seguro_de_64_caracteres

# ── Docker Registry ───────────────────────────────────────────────────────────
DOCKER_REGISTRY=turegistro.azurecr.io
IMAGE_TAG=latest
