# ─── Azure AD (te los da el admin de Azure cuando registren la app) ───────────
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── Base de datos (local: ya configurada en docker-compose) ──────────────────
# En producción cambia por la connection string de RDS
DATABASE_URL=postgresql://pmo_user:pmo_password_local@localhost:5432/pmo_portal

# ─── AWS S3 (solo en producción, local no es necesario) ──────────────────────
AWS_S3_BUCKET=pmo-portal-files
AWS_REGION=us-east-1

# ─── App ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
JWT_SECRET=cambia_esto_en_produccion_por_algo_seguro
